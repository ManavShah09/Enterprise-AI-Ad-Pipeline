# ==============================================================================
# Enterprise AI Ad Pipeline — Environment Configuration Template (.env.example)
# ==============================================================================
# Copy this file to '.env' and populate with your organization's credentials.
# WARNING: Never commit actual '.env' files containing live secrets to version control.

# ------------------------------------------------------------------------------
# 1. Azure AI Foundry / AI Projects Configuration
# ------------------------------------------------------------------------------
# You can find this in your Azure AI Foundry project's Overview page under 'Project details'.
# Format: https://<your-hub-name>.services.ai.azure.com/api/projects/<your-project-name>
PROJECT_CONNECTION_STRING="https://your-foundry-hub.services.ai.azure.com/api/projects/your-project"

# Deployment name of your deployed OpenAI model (e.g., gpt-4o or gpt-4o-mini)
MODEL_DEPLOYMENT_NAME="gpt-4o-mini"

# ------------------------------------------------------------------------------
# 2. Azure Cosmos DB (Gremlin Graph API) — Read-Only Connection
# ------------------------------------------------------------------------------
# WebSocket endpoint for your Cosmos DB Gremlin account
COSMOS_DB_ENDPOINT="wss://your-cosmos-account.gremlin.cosmos.azure.com:443/"

# Read-only primary or secondary key for the Cosmos DB database
COSMOS_DB_KEY="your-cosmos-db-read-only-key-here"

# The name of the database containing your organization's Marketing Foundation
COSMOS_DB_DATABASE="Your Organization Database"

# The name of the Gremlin graph containing the marketing entities
COSMOS_DB_GRAPH="Entity"

# ------------------------------------------------------------------------------
# 3. Service & Performance Configuration
# ------------------------------------------------------------------------------
# In-memory cache Time-To-Live (TTL) in seconds for foundation data (default: 300 = 5 min)
FOUNDATION_CACHE_TTL_SECONDS=300
